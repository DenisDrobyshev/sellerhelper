# Copy to .env and adjust. The open-source build runs entirely on your own keys.

# --- Database ---
POSTGRES_USER=sellercompass
POSTGRES_PASSWORD=sellercompass
POSTGRES_DB=sellercompass
DATABASE_URL=postgresql+asyncpg://sellercompass:sellercompass@localhost:5434/sellercompass

# --- Redis ---
REDIS_URL=redis://localhost:6381/0

# --- LLM (bring your own key) ---
LLM_API_KEY=
LLM_MODEL=

# --- Wildberries collector ---
# WB aggressively throttles datacenter IPs (HTTP 429). Run from a residential/RU
# network, or set an HTTP(S) proxy below. Keep the rate limit gentle.
WB_PROXY_URL=
WB_REQUESTS_PER_SECOND=0.5
WB_SEARCH_VERSION=v9
WB_DEST=-1257786
