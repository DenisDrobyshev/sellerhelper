# Copy to .env and adjust. The open-source build runs entirely on your own keys.

# --- Database ---
# Defaults to a local SQLite file. For Postgres, install a driver (psycopg) and use:
# DATABASE_URL=postgresql+psycopg://sellercompass:sellercompass@localhost:5434/sellercompass
DATABASE_URL=sqlite:///sellercompass.db

# --- Redis (reserved for the scheduler / queue) ---
REDIS_URL=redis://localhost:6381/0

# --- LLM (bring your own key) ---
LLM_API_KEY=
LLM_MODEL=

# --- Wildberries collectors ---
# The httpx collector is fast, but WB throttles IPs (HTTP 429). The Selenium
# spider drives a real browser and is far less likely to be blocked.
WB_PROXY_URL=
WB_REQUESTS_PER_SECOND=0.5
WB_SEARCH_VERSION=v9
WB_DEST=-1257786
WB_HEADLESS=true
